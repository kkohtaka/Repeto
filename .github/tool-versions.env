# Linter and development tool versions
# Update these versions to upgrade tools in both CI and local environment

# actionlint - GitHub Actions workflow linter
ACTIONLINT_VERSION=1.7.12

# markdownlint-cli2 - Markdown linter
MARKDOWNLINT_CLI2_VERSION=0.22.1

# SwiftLint - Swift code linter
SWIFTLINT_VERSION=0.63.2

# gh - GitHub CLI
GH_VERSION=2.92.0

# Node.js - JavaScript runtime for markdownlint
NODE_VERSION=24

# shellcheck - Shell script linter (required by actionlint)
SHELLCHECK_VERSION=0.11.0

# xcodegen - Xcode project file generator
XCODEGEN_VERSION=2.45.4
